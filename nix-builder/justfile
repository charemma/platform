set fallback := true

_default:
    @just --list

# Spin up all configured builders
up:
    pulumi up --yes

# Tear down all builders
down:
    pulumi destroy --yes

# Preview changes without applying
preview:
    pulumi preview

# Show running builders as JSON
status:
    @pulumi stack output output 2>/dev/null | jq . || echo "[]"

# Private key path the nix-daemon uses on build clients (deployed via sops-nix).
builder_key := "/etc/nix/nix-builder_ed25519"

# Print a NIX_BUILDERS string for the running builders.
# Usage: export NIX_BUILDERS="$(just nix-builder::builders-env)"
builders-env:
    @pulumi stack output output 2>/dev/null \
      | jq -r --arg key "{{ builder_key }}" \
        'map("ssh-ng://\(.user)@\(.host) \(.arch) \($key) \(.cores) 1 - - -") | join(";")'

# Install deps and init stack
init:
    npm install
    @echo "Run: pulumi stack init dev && pulumi config set hcloud:token --secret"
