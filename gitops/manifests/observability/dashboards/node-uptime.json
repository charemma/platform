        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "time() - node_boot_time_seconds{instance=\"aiagent.tail48929d.ts.net:9100\"}",
          "legendFormat": "aiagent",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "time() - node_boot_time_seconds{instance=\"localhost:9100\"}",
          "legendFormat": "vps",
          "refId": "B"
        }
      ],
      "title": "Uptime since last boot",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "text", "value": null}]},
          "unit": "dateTimeAsIso"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "node_boot_time_seconds{instance=\"aiagent.tail48929d.ts.net:9100\"} * 1000",
          "legendFormat": "aiagent",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "node_boot_time_seconds{instance=\"localhost:9100\"} * 1000",
          "legendFormat": "vps",
          "refId": "B"
        }
      ],
      "title": "Last boot",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total time each node was unreachable in the selected range. For aiagent in the kitchen, >4h likely means fridge contents at risk.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 300},
              {"color": "orange", "value": 3600},
              {"color": "red", "value": 14400}
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum_over_time((up{job=\"node\", instance=\"aiagent.tail48929d.ts.net:9100\"} == bool 0)[$__range:1m]) * 60",
          "legendFormat": "aiagent",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum_over_time((up{job=\"node\", instance=\"localhost:9100\"} == bool 0)[$__range:1m]) * 60",
          "legendFormat": "vps",
          "refId": "B"
        }
      ],
      "title": "Total downtime (range)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Green = node reachable, red = node unreachable. Every red band is a potential power or network outage. For aiagent, a red band longer than 4h is the fridge-safety threshold.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0,
            "spanNulls": false
          },
          "mappings": [
            {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "id": 5,
      "options": {
        "alignValue": "center",
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "never",
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "up{job=\"node\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Availability timeline",
      "type": "state-timeline"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Each drop from 1 to 0 marks the start of an outage. Zoom in to read the gap width.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "id": 6,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "up{job=\"node\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "up{} over time (all nodes)",
